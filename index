<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

<script>
  const EMAILJS_SERVICE_ID = 'service_fni5wum';
  const EMAILJS_TEMPLATE_ID = 'template_34gxgyf';
  const EMAILJS_PUBLIC_KEY = 'AKh5p4WjsFDvVyOI7';

  if (window.emailjs) {
    emailjs.init({
      publicKey: EMAILJS_PUBLIC_KEY
    });
  }

  const screen = document.getElementById('screen');
  const cover  = document.getElementById('cover');
  const invitation = document.querySelector('.invitation');

  const confirmBtn = document.getElementById('confirmBtn');
  const calendarBtn = document.getElementById('calendarBtn');
  const rsvpModal = document.getElementById('rsvpModal');
  const rsvpClose = document.getElementById('rsvpClose');
  const rsvpForm = document.getElementById('rsvpForm');

  const rsvpRecipients = 'amouzegarjulei@gmail.com,michael.tcha@gmail.com';
  const weddingAddress = '1 Pl. du 27 Mars 2002, 92000 Nanterre, France';

  const params = new URLSearchParams(window.location.search);
  const guestName = String(params.get('name') || '').trim();
  const guestNameText = document.getElementById('guestNameText');

  if (guestNameText && guestName) {
    guestNameText.textContent = guestName;
  }

  let opened = false;

  function openInvitation() {
    if (opened) return;
    opened = true;

    screen.classList.add('pressing');

    setTimeout(() => {
      screen.classList.add('open');
    }, 460);

    setTimeout(() => {
      invitation.setAttribute('aria-hidden', 'false');
      cover.setAttribute('aria-hidden', 'true');
      cover.tabIndex = -1;
      screen.classList.remove('pressing');
    }, 1710);
  }

  function openRsvpModal() {
    rsvpModal.hidden = false;
    requestAnimationFrame(() => {
      rsvpModal.classList.add('active');
      rsvpModal.setAttribute('aria-hidden', 'false');
      document.getElementById('rsvpNom').focus();
    });
  }

  function closeRsvpModal() {
    rsvpModal.classList.remove('active');
    rsvpModal.setAttribute('aria-hidden', 'true');
    setTimeout(() => { rsvpModal.hidden = true; }, 260);
  }

  function addToNativeCalendar() {
    const ics = [
      'BEGIN:VCALENDAR',
      'VERSION:2.0',
      'PRODID:-//Michael et Julie//Faire-part//FR',
      'CALSCALE:GREGORIAN',
      'METHOD:PUBLISH',
      'BEGIN:VEVENT',
      'UID:michael-julie-mariage-20250912T150000@fairepart',
      'DTSTAMP:20250602T120000Z',
      'DTSTART:20250912T130000Z',
      'DTEND:20250912T140000Z',
      'SUMMARY:Mariage Michaël & Julie',
      'LOCATION:' + weddingAddress,
      'DESCRIPTION:Cérémonie de mariage de Michaël et Julie.',
      'END:VEVENT',
      'END:VCALENDAR'
    ].join('\r\n');

    const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = 'mariage-michael-julie.ics';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  cover.addEventListener('click', openInvitation);

  cover.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      openInvitation();
    }
  });

  confirmBtn.addEventListener('click', openRsvpModal);
  calendarBtn.addEventListener('click', addToNativeCalendar);

  rsvpClose.addEventListener('click', closeRsvpModal);

  rsvpModal.addEventListener('click', e => {
    if (e.target === rsvpModal) closeRsvpModal();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !rsvpModal.hidden) closeRsvpModal();
  });

  rsvpForm.addEventListener('submit', e => {
    e.preventDefault();

    if (!window.emailjs) {
      alert("EmailJS n'est pas chargé. Teste le fichier avec une connexion internet ou héberge-le sur ton site.");
      return;
    }

    const formData = new FormData(rsvpForm);
    const nom = String(formData.get('nom') || '').trim();
    const prenom = String(formData.get('prenom') || '').trim();
    const ceremonie = String(formData.get('ceremonie') || 'Non');
    const diner = String(formData.get('diner') || 'Non');

    const subject = `Confirmation présence - ${prenom} ${nom}`;
    const message = [
      'Nouvelle confirmation de présence',
      '',
      `Nom : ${nom}`,
      `Prénom : ${prenom}`,
      `Cérémonie : ${ceremonie}`,
      `Dîner : ${diner}`
    ].join('\n');

    const submitButton = rsvpForm.querySelector('.rsvp-submit');
    const originalButtonText = submitButton.textContent;

    submitButton.disabled = true;
    submitButton.textContent = 'Envoi...';

    emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
      nom: nom,
      prenom: prenom,
      ceremonie: ceremonie,
      diner: diner,
      subject: subject,
      message: message,
      to_email: rsvpRecipients,
      from_name: `${prenom} ${nom}`
    }).then(() => {
      alert('Merci, votre réponse a bien été envoyée.');
      rsvpForm.reset();
      closeRsvpModal();
    }).catch(error => {
      console.error('Erreur EmailJS :', error);
      const errorText = error && (error.text || error.message) ? (error.text || error.message) : 'Erreur inconnue';
      alert("L'envoi n'a pas fonctionné. Vérifie EmailJS > Email History / Logs. Détail : " + errorText);
    }).finally(() => {
      submitButton.disabled = false;
      submitButton.textContent = originalButtonText;
    });
  });
</script>
